{
  "name": "wait-for-lsp-rust",
  "description": "Rust language server (rust-analyzer) via wait-for-lsp proxy — filters stale diagnostics",
  "version": "0.1.0",
  "lspServers": {
    "rust-analyzer": {
      "command": "sh",
      "args": ["-c", "STAY_FRESH_LOG=true /Users/tony/programming/wait-for-lsp/target/release/wait-for-lsp rust-analyzer 2>/tmp/wait-for-lsp-err.log"],
      "extensionToLanguage": {
        ".rs": "rust"
      }
    }
  }
}
